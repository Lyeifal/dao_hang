---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Base64 编解码 | 工具聚合" description="Base64 字符串编码与解码工具">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <a href="/tools" class="text-sm text-primary hover:text-primary-dark font-medium mb-4 inline-block">
        ← 返回工具聚合
      </a>
      <h1 class="text-3xl font-bold text-text mb-3">Base64 编解码</h1>
      <p class="text-text-muted">快速进行 Base64 字符串编码与解码，支持中文</p>
    </div>

    <div class="space-y-6">
      <!-- Input -->
      <div>
        <label class="block text-sm font-medium text-text mb-2">输入文本</label>
        <textarea
          id="input"
          rows="5"
          class="w-full px-4 py-3 rounded-xl border-2 border-border bg-white text-text placeholder:text-text-muted focus:border-primary focus:outline-none resize-y font-mono text-sm"
          placeholder="在此输入需要编码或解码的内容..."
        ></textarea>
      </div>

      <!-- Buttons -->
      <div class="flex flex-wrap gap-3">
        <button
          id="encodeBtn"
          class="px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-dark transition-colors"
        >
          编码 → Base64
        </button>
        <button
          id="decodeBtn"
          class="px-5 py-2.5 rounded-lg bg-white text-text border-2 border-border text-sm font-medium hover:border-primary transition-colors"
        >
          解码 ← Base64
        </button>
        <button
          id="clearBtn"
          class="px-5 py-2.5 rounded-lg bg-white text-text-muted border-2 border-border text-sm font-medium hover:border-red-300 hover:text-red-600 transition-colors"
        >
          清空
        </button>
        <button
          id="swapBtn"
          class="px-5 py-2.5 rounded-lg bg-white text-text-muted border-2 border-border text-sm font-medium hover:border-primary transition-colors"
        >
          交换
        </button>
      </div>

      <!-- Output -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm font-medium text-text">结果</label>
          <button
            id="copyBtn"
            class="text-xs text-primary hover:text-primary-dark font-medium"
          >
            复制结果
          </button>
        </div>
        <textarea
          id="output"
          rows="5"
          readonly
          class="w-full px-4 py-3 rounded-xl border-2 border-border bg-surface-alt text-text focus:border-primary focus:outline-none resize-y font-mono text-sm"
          placeholder="结果将显示在这里..."
        ></textarea>
      </div>

      <!-- Error -->
      <div id="error" class="hidden p-4 rounded-lg bg-red-50 text-red-600 text-sm"></div>
    </div>
  </div>

  <script>
    const input = document.getElementById('input');
    const output = document.getElementById('output');
    const error = document.getElementById('error');
    const encodeBtn = document.getElementById('encodeBtn');
    const decodeBtn = document.getElementById('decodeBtn');
    const clearBtn = document.getElementById('clearBtn');
    const swapBtn = document.getElementById('swapBtn');
    const copyBtn = document.getElementById('copyBtn');

    function showError(msg) {
      error.textContent = msg;
      error.classList.remove('hidden');
    }

    function hideError() {
      error.classList.add('hidden');
    }

    encodeBtn.addEventListener('click', () => {
      hideError();
      try {
        const text = input.value;
        if (!text) return;
        // Support Chinese via encodeURIComponent
        const encoded = btoa(encodeURIComponent(text));
        output.value = encoded;
      } catch (e) {
        showError('编码失败：' + e.message);
      }
    });

    decodeBtn.addEventListener('click', () => {
      hideError();
      try {
        const text = input.value.trim();
        if (!text) return;
        const decoded = decodeURIComponent(atob(text));
        output.value = decoded;
      } catch (e) {
        showError('解码失败：输入内容不是有效的 Base64 字符串');
      }
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      output.value = '';
      hideError();
      input.focus();
    });

    swapBtn.addEventListener('click', () => {
      const temp = input.value;
      input.value = output.value;
      output.value = temp;
      hideError();
    });

    copyBtn.addEventListener('click', async () => {
      if (!output.value) return;
      try {
        await navigator.clipboard.writeText(output.value);
        const original = copyBtn.textContent;
        copyBtn.textContent = '已复制！';
        setTimeout(() => copyBtn.textContent = original, 1500);
      } catch {
        showError('复制失败，请手动复制');
      }
    });
  </script>
</Layout>
